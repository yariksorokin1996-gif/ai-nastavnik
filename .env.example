# ======================================
# AI Наставник (Ева) — Конфигурация
# ======================================
# Скопируй этот файл в .env и заполни ключи:
#   cp .env.example .env

# 1. Telegram Bot Token
#    Создай бота: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_token_here

# 2. Anthropic API Key (Claude — диалог)
#    Получи: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_key_here

# 3. OpenAI API Key (GPT-4o-mini — фоновые задачи, Whisper — голос)
#    Получи: https://platform.openai.com → API Keys
OPENAI_API_KEY=your_key_here

# 4. Telegram ID владельца (для алертов и отчётов)
#    Узнай: отправь /start боту @userinfobot
OWNER_TELEGRAM_ID=0

# 5. URL веб-приложения (опционально, для Mini App кнопки)
#    Пример: https://ai-nastavnik-production.up.railway.app
# WEBAPP_URL=
